# Database
DATABASE_URL="postgresql://postgres:password@host:5432/helpdesk"

# Server
PORT=3001
NODE_ENV=production

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-here
BETTER_AUTH_URL=https://your-app.up.railway.app
TRUSTED_ORIGINS=https://your-frontend-app.vercel.app

# Admin Account (used for seeding)
ADMIN_EMAIL=admin@helpdesk.com
ADMIN_PASSWORD=change-me-in-production

# Resend Email
RESEND_API_KEY=re_xxx_your_resend_api_key
RESEND_FROM_EMAIL=support@helpdesk.com

# MiniMax AI (for ticket classification and suggestions)
MINIMAX_API_KEY=your_minimax_api_key

# Frontend API URL (for Vite - used at build time)
VITE_API_URL="https://your-backend-app.up.railway.app"