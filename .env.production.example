# Database
DATABASE_URL="postgresql://postgres:password@host:5432/helpdesk"

# Server
PORT=3001
NODE_ENV=production

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-here
BETTER_AUTH_URL=https://your-app.up.railway.app
TRUSTED_ORIGINS=https://your-app.up.railway.app

# Sentry
SENTRY_DSN=https://your-backend-dsn@sentry.io/project
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=https://your-frontend-dsn@sentry.io/project
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
SENTRY_AUTH_TOKEN=

# Admin Account (used for seeding)
ADMIN_EMAIL=admin@helpdesk.com
ADMIN_PASSWORD=change-me-in-production

# Resend Email
RESEND_API_KEY=re_xxx_your_resend_api_key
RESEND_FROM_EMAIL=support@helpdesk.com

# MiniMax AI
MINIMAX_API_KEY=your_minimax_api_key

# Frontend API URL
# Leave empty when Express serves the Vite build from the same Railway service.
VITE_API_URL=""
