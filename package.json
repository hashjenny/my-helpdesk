{
  "name": "my-helpdesk",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "npm run build --prefix shared && npm run build --prefix backend && npm run build --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "test:frontend": "npm test --prefix frontend -- --run",
    "test": "npm run build --prefix shared && playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "show-report": "playwright show-report"
  },
  "dependencies": {}
}
